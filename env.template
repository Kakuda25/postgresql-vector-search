# PostgreSQL設定
POSTGRES_DB=dentalDB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# pgAdmin設定（オプション）
# PGADMIN_EMAIL: ログイン時のユーザー名（有効なメールアドレス形式である必要があります。@記号を含む必要があります）
# 例: admin@example.com
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password_here
PGADMIN_PORT=5050

